{
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "moduleResolution": "bundler",
      "types": ["node", "cypress"],
      "skipLibCheck": true,
      "noEmit": true,
      "strict": true,
      "esModuleInterop": true,
      "resolveJsonModule": true
    },
    "include": ["e2e/**/*.ts", "**/*.ts", "../cypress.config.ts"]
  }
  
